{
  "compilerOptions": {
    "lib": ["es2018"],
    "target": "es2018",
    "outDir": "./dist",

    "allowJs": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
    "strict": true,
    "module": "commonjs",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },

  "include": ["./src/**/*.js", "./src/**/*.ts"]
}
